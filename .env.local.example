# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_your-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox (address autocomplete on the trip edit form).
# Free tier: 100k geocoding requests/mo. Get a token at
# https://account.mapbox.com/access-tokens/ — a public (pk.*) token is fine.
# If unset, the address field gracefully degrades to a plain text input.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token
